\begin_layout Paragraph
Distribution of ordered statistics for 1d distribution
\end_layout

\begin_layout Standard
For 1d distribution,
 with PDF 
\begin_inset Formula $f(.)$
\end_inset

 and CDF 
\begin_inset Formula $F(.)$
\end_inset

.
 Then the PDF of the order statistics 
\begin_inset Formula $i$
\end_inset

th in 
\begin_inset Formula $\lambda$
\end_inset

 samples have the form.
 
\begin_inset Formula 
\[
f_{i:\lambda}(z)=\frac{\lambda!}{(i-1)!(\lambda-i)!}[F(z)]^{i-1}[1-F(z)]^{\lambda-i}f(z)
\]

\end_inset


\end_layout

