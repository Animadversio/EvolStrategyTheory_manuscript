\begin_body

\begin_layout Section
Theory of evolutionary strategy
\end_layout

\begin_layout Standard
Question:
 How population size 
\begin_inset Formula $\lambda$
\end_inset

 scaling with dimensionality 
\begin_inset Formula $d$
\end_inset


\end_layout

\begin_layout Subsection
Set up of Evolutionary Strategy
\end_layout

\begin_layout Standard
Consider a Gaussian sampling,
 without loss of generality,
 start from 
\begin_inset Formula $0$
\end_inset

,
 Here let's consider isotropic Gaussian sampling,
 which is usually accurate for high dimensional CMA-ES.
 
\begin_inset Formula 
\[
\mathbf{x}_{i}\sim\mathcal{N}(0,\sigma^{2}I)
\]

\end_inset


\end_layout

\begin_layout Standard
Keep the dependency on the step size 
\begin_inset Formula $\sigma$
\end_inset

,
\begin_inset Formula 
\[
\Delta\mathbf{m}=\sum_{i}^{\lambda}w_{k(i)}\mathbf{x}_{i}
\]

\end_inset


\end_layout

\begin_layout Paragraph
CMAES weighting scheme
\end_layout

\begin_layout Standard
The weighting term comes from the ranking 
\begin_inset Formula $k$
\end_inset

 of each sample,
 where 
\begin_inset Formula $K=[\tfrac{\lambda}{2}]_{-}$
\end_inset

 is the number of the samples it kept,
 in general,
 it's half the population size.
 
\begin_inset Formula 
\begin{align*}
w_{k}^{\prime} & =\ln\left(K+\tfrac{1}{2}\right)-\ln(k)=\ln\left(\frac{K+\tfrac{1}{2}}{k}\right)\\
w_{k} & =\frac{w_{i}^{\prime}}{\sum_{j}w_{j}^{\prime}}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsection
Linear function gradient estimation 
\end_layout

\begin_layout Standard
Consider a linear target function 
\begin_inset Formula $f(\mathbf{x})=\mathbf{v}^{\top}\mathbf{x}$
\end_inset

,
 
\begin_inset Formula $\mathcal{L}(\mathbf{w})$
\end_inset

,
 where the 
\begin_inset Formula $\mathbf{v}$
\end_inset

 is the gradient direction or the steepest ascent direction.
 
\end_layout

\begin_layout Standard
So the fitness score only depends on the projection of 
\begin_inset Formula $\mathbf{x}$
\end_inset

 on one direction 
\begin_inset Formula $\mathbf{v}$
\end_inset

,
 
\end_layout

\begin_layout Standard
The update of the mean equals,
 
\begin_inset Formula 
\begin{align*}
\Delta\mathbf{m} & =\sum_{i}^{K}w_{k(i)}\mathbf{x}_{i}\\
 & =\sum_{i}^{K}w_{k(i)}(P_{v}\mathbf{x}_{i}+P_{v}^{\perp}\mathbf{x}_{i})\\
 & =\sum_{i}^{K}w_{k(i)}(x_{i}^{v}\frac{\mathbf{v}}{\|\mathbf{v}\|}+\mathbf{x}_{i}^{\perp})\\
 & =(\sum_{i}^{K}w_{k(i)}x_{i}^{v})\frac{\mathbf{v}}{\|\mathbf{v}\|}+\sum_{i}^{K}w_{k(i)}\mathbf{x}_{i}^{\perp}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
This shows that the mean update can be decomposed into two terms,
 on manifold and off manifold one.
\begin_inset Formula 
\begin{align*}
\Delta\mathbf{m} & =\underbrace{(\sum_{i}^{K}w_{k(i)}x_{i}^{v})\frac{\mathbf{v}}{\|\mathbf{v}\|}}_{\Delta\mathbf{m}^{\parallel}}+\underbrace{\sum_{i}^{K}w_{k(i)}\mathbf{x}_{i}^{\perp}}_{\Delta\mathbf{m}^{\perp}}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Recognizing a few independence,
 note that 
\end_layout

\begin_layout Itemize
the 
\begin_inset Formula $x_{i}^{v}$
\end_inset

 and 
\begin_inset Formula $\mathbf{x}_{i}^{\perp}$
\end_inset

 are independent to each other,
 due to isotropic Gaussian.
\end_layout

\begin_layout Itemize
the score 
\begin_inset Formula $f(\mathbf{x}_{i})$
\end_inset

 is independent of 
\begin_inset Formula $\mathbf{x}_{i}^{\perp}$
\end_inset

 in the linear case,
 thus the 
\begin_inset Formula $\mathbf{x}_{i}^{\perp}$
\end_inset

 and the ranking 
\begin_inset Formula $k(i)$
\end_inset

 and weighting 
\begin_inset Formula $w_{k(i)}$
\end_inset

 are independent to each other.
 Thus it's the same as weighting 
\begin_inset Formula $K$
\end_inset

 i.i.d.
 Gaussian samples 
\begin_inset Formula $\mathbf{x}_{i}^{\perp}$
\end_inset

,
 which remains Gaussian with closed form variance.
 
\end_layout

\begin_layout Paragraph
Off-axis term
\end_layout

\begin_layout Standard
distribution of it is Gaussian,
 
\begin_inset Formula 
\begin{align*}
\Delta\mathbf{m}^{\perp}=\sum_{i}^{K}w_{k(i)}\mathbf{x}_{i}^{\perp} & =\sum_{i}^{K}w_{k}\mathbf{x}_{k}^{\perp}\\
 & \sim\mathcal{N}\Big(0,\sigma^{2}(\sum_{k}^{K}w_{k}^{2})\big(I-\frac{\mathbf{v}\mathbf{v}^{\top}}{\|\mathbf{v}\|^{2}}\big)\Big)\\
 & \sim\mathcal{N}\Big(0,\sigma^{2}(\sum_{k}w_{k}^{2})P_{v}^{\perp}\Big)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
this term is totally Gaussian which has 
\begin_inset Formula $0$
\end_inset

 bias and isotropic distribution,
 off the 
\begin_inset Formula $\mathbf{v}$
\end_inset

 axis.
 
\end_layout

\begin_layout Paragraph
On-axis term 
\end_layout

\begin_layout Standard
The on axis 
\begin_inset Formula 
\[
\Delta\mathbf{m}^{\parallel}=(\sum_{i}^{K}w_{k(i)}x_{i}^{v})\frac{\mathbf{v}}{\|\mathbf{v}\|}
\]

\end_inset


\end_layout

\begin_layout Standard
This is can be equivalently expressed as:
 sampling 
\begin_inset Formula $\lambda$
\end_inset

 standard norm variable 
\begin_inset Formula $\{z_{i}\}$
\end_inset

,
 then we pick the 
\begin_inset Formula $z_{k:\lambda}$
\end_inset

,
 i.e.
 the kth largest value in 
\begin_inset Formula $\lambda$
\end_inset

 samples,
 kth order statistics.
 Then
\begin_inset Formula 
\[
\Delta\mathbf{m}^{\parallel}=(\sum_{i}^{K}w_{k(i)}x_{i}^{v})\frac{\mathbf{v}}{\|\mathbf{v}\|}=(\sigma\sum_{k}^{K}w_{k}z_{k:\lambda})\frac{\mathbf{v}}{\|\mathbf{v}\|}
\]

\end_inset


\end_layout

\begin_layout Standard
This term is non Gaussian,
 and the expectation of it can be expressed 
\begin_inset Formula 
\[
\mathbb{E}[\Delta\mathbf{m}^{\parallel}]=(\sigma\sum_{k}^{K}w_{k}\mathbb{E}[z_{k:\lambda}])\frac{\mathbf{v}}{\|\mathbf{v}\|}
\]

\end_inset


\end_layout

\begin_layout Standard
where 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[z_{k:\lambda}] & =\int_{-\infty}^{\infty}z\ f_{k:\lambda}(z)dz\\
 & =\int_{-\infty}^{\infty}z\frac{\lambda!}{(k-1)!(\lambda-i)!}[\Phi(z)]^{k-1}[1-\Phi(z)]^{\lambda-k}\phi(z)dz
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
We can also estimate the variance of the on axis term 
\begin_inset Formula 
\[
\text{Var}[\Delta\mathbf{m}^{\parallel}]=\sigma^{2}\sum_{k}^{K}\sum_{k^{\prime}}^{K}w_{k}w_{k^{\prime}}\text{Cov}[z_{k:\lambda},z_{k^{\prime}:\lambda}]
\]

\end_inset


\end_layout

\begin_layout Standard
where the joint distribution of the ordered statistics is more tricky,
 but can still be calculated.
 
\end_layout

\begin_layout Standard
\begin_inset Box Frameless
position "t"
hor_pos "c"
has_inner_box 1
inner_pos "t"
use_parbox 0
use_makebox 0
width "100col%"
special "none"
height "1in"
height_special "totalheight"
thickness "0.4pt"
separation "3pt"
shadowsize "4pt"
framecolor "default"
backgroundcolor "none"
status open

\begin_layout Plain Layout
For joint distribution of 
\begin_inset Formula $i,j$
\end_inset

th ordered statistics 
\begin_inset Formula $(Z_{i:\lambda},Z_{j:\lambda})$
\end_inset

,
 
\begin_inset Formula $1\le i<j\le\lambda$
\end_inset

,
 and 
\begin_inset Formula $Z_{i:\lambda}<Z_{j:\lambda}$
\end_inset

.
 
\end_layout

\begin_layout Plain Layout
We have pdf of the joint distribution
\begin_inset Formula 
\[
f_{i,j}(x,y)=\frac{\lambda!}{(i-1)!\,(j-i-1)!\,(\lambda-j)!}\;[\Phi(x)]^{\,i-1}\;[\Phi(y)-\Phi(x)]^{\,j-i-1}\;[1-\Phi(y)]^{\,\lambda-j}\;\phi(x)\,\phi(y)
\]

\end_inset


\end_layout

\begin_layout Plain Layout
and 
\begin_inset Formula $f_{i,j}(x,y)=0$
\end_inset

 if 
\begin_inset Formula $x>y$
\end_inset

.
 
\end_layout

\end_inset


\end_layout

\begin_layout Standard
Through this we can compute the cosine angle with 
\begin_inset Formula $\mathbf{v}$
\end_inset

,
 i.e.
 gradient of the target function in linear case.
 
\begin_inset Formula 
\[
\cos(\Delta\mathbf{m},\mathbf{v})=\frac{\|\Delta\mathbf{m}^{\parallel}\|}{\|\Delta\mathbf{m}\|}=\sqrt{\frac{\|\Delta\mathbf{m}^{\parallel}\|^{2}}{\|\Delta\mathbf{m}^{\parallel}\|^{2}+\|\Delta\mathbf{m}^{\perp}\|^{2}}}
\]

\end_inset


\begin_inset Formula 
\begin{align*}
\|\Delta\mathbf{m}^{\perp}\|^{2} & \sim\sigma^{2}(d-1)(\sum_{k}^{K}w_{k}^{2})\\
\|\Delta\mathbf{m}^{\parallel}\|^{2} & \sim\sigma^{2}(\sum_{k}^{K}w_{k}\mathbb{E}[z_{k:\lambda}])^{2}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Key observation about the cosine with gradient 
\end_layout

\begin_layout Itemize
On manifold term squared norm 
\end_layout

\begin_deeper
\begin_layout Itemize
It is invariant of the search space dimensionality 
\begin_inset Formula $d$
\end_inset


\end_layout

\begin_layout Itemize
It depends on the population size 
\begin_inset Formula $K$
\end_inset

 via 
\begin_inset Formula $(\sum_{k}^{K}w_{k}\mathbb{E}[z_{k:\lambda}])^{2}$
\end_inset

,
 i.e.
 weighted sum of Gaussian order statistics.
 But this term is a bit bounded.
 
\end_layout

\end_deeper
\begin_layout Itemize
Off manifold term squared norm 
\end_layout

\begin_deeper
\begin_layout Itemize
Depends on the search space dimensionality 
\begin_inset Formula $d$
\end_inset

,
 it linearly scale with the dimensionality 
\begin_inset Formula $d-2$
\end_inset

 (the norm scale with square root of 
\begin_inset Formula $d$
\end_inset

)
\end_layout

\begin_layout Itemize
Depends on the population size via 
\begin_inset Formula $\sum_{k}^{K}w_{k}^{2}$
\end_inset

,
 larger population scale down the off manifold variance.
 
\end_layout

\end_deeper
\begin_layout Subsection
Quadratic target function
\end_layout

\begin_layout Standard
Consider a local quadratic function model 
\begin_inset Formula 
\begin{align*}
f(\mathbf{x}) & =-\frac{1}{2}(\mathbf{x}-\mathbf{b})^{\top}H(\mathbf{x}-\mathbf{b})\\
 & =-\frac{1}{2}\mathbf{x}^{\top}H\mathbf{x}+\mathbf{b}H\mathbf{x}-\frac{1}{2}\mathbf{b}^{\top}H\mathbf{b}\\
 & \equiv-\frac{1}{2}\mathbf{x}^{\top}H\mathbf{x}+\mathbf{q}^{\top}\mathbf{x}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Consider the update rule 
\begin_inset Formula 
\[
\Delta\mathbf{m}=\sum_{i}^{\lambda}(f(\mathbf{x}_{i})-c)\mathbf{x}_{i}
\]

\end_inset


\end_layout

\begin_layout Subsection
Simplified ES
\end_layout

\begin_layout Standard
Consider the ES algorithm actually used in LLM training (cite)
\end_layout

\begin_layout Subsubsection
Set up
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\theta_{t+1}=\theta_{t}+\alpha\cdot\frac{1}{N}\sum_{i=1}^{N}Z_{i}\epsilon_{i}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula $\epsilon_{i}\sim\mathcal{N}(0,I_{d})$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula $Z_{i}=\frac{R_{i}-\mu_{R}}{\sigma_{R}}$
\end_inset

 
\end_layout

\begin_layout Standard
\begin_inset Formula $R_{i}=R(\theta_{t}+\sigma\epsilon_{i})$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula $\alpha=\frac{1}{2}\sigma$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula $N\approx30$
\end_inset


\end_layout

\begin_layout Standard
The weight update is 
\begin_inset Formula 
\[
\Delta\theta=\alpha\cdot\frac{1}{N}\sum_{i=1}^{N}Z_{i}\epsilon_{i}
\]

\end_inset


\end_layout

\begin_layout Standard
The key assumption is 
\begin_inset Formula $Z_{i}$
\end_inset

 is independent to 
\begin_inset Formula $\epsilon_{i}$
\end_inset

,
 i.e.
 
\begin_inset Formula $Z_{i}\perp\epsilon_{i}$
\end_inset

,
 then we can write down the distribution of 
\begin_inset Formula $\Delta\theta$
\end_inset

 conditioned on a set of 
\begin_inset Formula $Z_{i}$
\end_inset


\begin_inset Formula 
\[
Var[\Delta\theta|Z_{i}]=\Big(\frac{\alpha^{2}}{N^{2}}\sum_{i}^{N}Z_{i}^{2}\Big)I_{d}
\]

\end_inset


\end_layout

\begin_layout Standard
The distribution is an isotropic Gaussian 
\begin_inset Formula 
\[
\Delta\theta|Z_{i}\sim\mathcal{N}\big(0,\Big(\frac{\alpha^{2}}{N^{2}}\sum_{i}^{N}Z_{i}^{2}\Big)I_{d}\big)
\]

\end_inset


\end_layout

\begin_layout Standard
Note that 
\begin_inset Formula $Z_{i}=\frac{R_{i}-\mu_{R}}{\sigma_{R}}$
\end_inset

,
 by definition,
\begin_inset Formula 
\begin{align*}
\sum_{i=1}^{N}Z_{i}^{2} & =\sum_{i=1}^{N}(\frac{R_{i}-\mu_{R}}{\sigma_{R}})^{2}\\
 & =\frac{1}{\sigma_{R}^{2}}\sum_{i=1}^{N}(R_{i}-\mu_{R})^{2}\\
 & =N\text{(or \ensuremath{N-1})}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Thus the general scaling will be 
\begin_inset Formula 
\begin{align*}
Var[\Delta\theta|Z_{i}] & =\frac{\alpha^{2}}{N^{2}}NI_{d}\\
 & =\frac{\sigma^{2}}{4N}I_{d}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Note that this is independent of the choice of 
\begin_inset Formula $Z_{i}$
\end_inset

,
 thus marginalizing over 
\begin_inset Formula $Z_{i}$
\end_inset

 we have the same distribution 
\begin_inset Formula 
\[
\Delta\theta\sim\mathcal{N}\big(0,\frac{\sigma^{2}}{4N}I_{d}\big)
\]

\end_inset


\begin_inset Formula 
\[
Var[\Delta\theta]=\frac{\sigma^{2}}{4N}I_{d}
\]

\end_inset


\end_layout

\begin_layout Standard
On flat landscape,
 the 
\begin_inset Formula $\Delta\theta$
\end_inset

 will be independent across steps,
 thus after 
\begin_inset Formula $T$
\end_inset

 steps the combined weight change 
\begin_inset Formula 
\[
\bar{\Delta\theta_{T}}=\theta_{T}-\theta_{0}=\sum_{t=1}^{T}\Delta\theta_{t}
\]

\end_inset


\end_layout

\begin_layout Standard
Thus the combined variance is 
\begin_inset Formula 
\[
Var[\bar{\Delta\theta_{T}}]=\frac{\sigma^{2}T}{4N}I_{d}
\]

\end_inset


\end_layout

\begin_layout Standard
Thus,
 the expected squared norm of weight deviation is 
\begin_inset Formula 
\[
\mathbb{E}\|\bar{\Delta\theta_{T}}\|^{2}=\frac{\sigma^{2}Td}{4N}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Consider the case of flat landscape without noise,
 Then 
\begin_inset Formula $R_{i}=const$
\end_inset

.
 
\end_layout

\begin_layout Plain Layout
Consider flat landscape with noise 
\begin_inset Formula $R_{i}\sim\mathcal{N}(0,\sigma_{r}^{2})$
\end_inset

 where 
\begin_inset Formula $\sigma_{r}$
\end_inset

 is the population level std.
 
\end_layout

\begin_layout Plain Layout
In this case 
\begin_inset Formula $Z_{i}\sim\mathcal{N}()$
\end_inset

 student t distribution?
 
\end_layout

\begin_layout Plain Layout
Approximately 
\begin_inset Formula $Z_{i}\sim\mathcal{N}(0,1)$
\end_inset


\end_layout

\begin_layout Plain Layout
then consider the 
\begin_inset Formula $Z_{i}$
\end_inset

 
\end_layout

\end_inset


\end_layout

\begin_layout Subsubsection
Linear landscape
\end_layout

\begin_layout Standard
Consider a linear landscape with i.i.d.
 observational noise 
\begin_inset Formula $\xi\sim\mathcal{N}(0,1)$
\end_inset

 assume it's independent of the exploration vector 
\begin_inset Formula $\xi\perp\epsilon$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
R(\theta)=-\mathbf{v}^{\top}\theta
\]

\end_inset


\end_layout

\begin_layout Standard
The observed reward at each location is,
 
\begin_inset Formula 
\begin{align*}
R_{i} & =R(\theta_{0}+\sigma\epsilon_{i})+\sigma_{\xi}\xi_{i}\\
 & =-\mathbf{v}^{\top}(\theta_{0}+\sigma\epsilon_{i})+\sigma_{\xi}\xi_{i}\\
 & \equiv-\sigma\mathbf{v}^{\top}\epsilon_{i}+\sigma_{\xi}\xi_{i}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Decompose the exploration to be on-manifold and off-manifold component 
\begin_inset Formula 
\[
\epsilon_{i}=\epsilon_{i}^{\perp}+\epsilon_{i}^{\parallel}
\]

\end_inset


\end_layout

\begin_layout Standard
where 
\begin_inset Formula $\epsilon_{i}^{\perp}:=P^{\perp}\epsilon_{i},\epsilon_{i}^{\parallel}:=P^{\parallel}\epsilon_{i}$
\end_inset


\begin_inset Formula 
\begin{align*}
P^{\perp} & :=I-\frac{\mathbf{v}\mathbf{v}^{\top}}{\|\mathbf{v}\|^{2}}\\
P^{\parallel} & :=\frac{\mathbf{v}\mathbf{v}^{\top}}{\|\mathbf{v}\|^{2}}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Given isotropic Gaussian noise,
 each 
\begin_inset Formula $\epsilon_{i}^{\perp}$
\end_inset

 is distributed i.i.d.
 
\begin_inset Formula $\epsilon_{i}^{\perp}\sim\mathcal{N}(0,P^{\perp})$
\end_inset

 and 
\begin_inset Formula $\epsilon_{i}^{\parallel}\sim\mathcal{N}(0,P^{\parallel})$
\end_inset

.
 
\begin_inset Formula $\epsilon_{i}^{\perp}$
\end_inset

 and 
\begin_inset Formula $\epsilon_{i}^{\parallel}$
\end_inset

 are statistically independent 
\begin_inset Formula $\epsilon_{i}^{\perp}\perp\epsilon_{i}^{\parallel}$
\end_inset

.
 
\end_layout

\begin_layout Standard
Also note that 
\begin_inset Formula 
\begin{align*}
R_{i} & =-\sigma\mathbf{v}^{\top}\epsilon_{i}+\sigma_{\xi}\xi_{i}\\
 & =-\sigma\mathbf{v}^{\top}\epsilon_{i}^{\parallel}+\sigma_{\xi}\xi_{i}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
the reward depends on the on-manifold component,
 so statistically it's independent of the off-manifold component 
\begin_inset Formula $R_{i}\perp\epsilon_{i}^{\perp}$
\end_inset

.
 
\end_layout

\begin_layout Standard
We are going to examine the statistical property of the weight update step
\begin_inset Formula 
\[
\Delta\theta=\alpha\cdot\frac{1}{N}\sum_{i=1}^{N}Z_{i}\epsilon_{i}
\]

\end_inset


\end_layout

\begin_layout Standard
Consider the weight update step on- and off-manifold
\begin_inset Formula 
\[
\Delta\theta=P^{\perp}\Delta\theta+P^{\parallel}\Delta\theta
\]

\end_inset


\end_layout

\begin_layout Paragraph
Off-manifold component
\begin_inset Formula 
\begin{align*}
P^{\perp}\Delta\theta & =\alpha\cdot\frac{1}{N}\sum_{i=1}^{N}Z_{i}P^{\perp}\epsilon_{i}\\
 & =\alpha\cdot\frac{1}{N}\sum_{i=1}^{N}Z_{i}\epsilon_{i}^{\perp}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Conditioned on the observed normalized reward 
\begin_inset Formula $Z_{i}$
\end_inset

,
 
\begin_inset Formula $P^{\perp}\Delta\theta$
\end_inset

 is weighted sum of Gaussian random vectors,
 thus Gaussian 
\begin_inset Formula 
\[
P^{\perp}\Delta\theta\mid\{Z_{i}\}_{i=1}^{N}\sim\mathcal{N}\Big(0,\frac{\alpha^{2}}{N^{2}}\sum_{i=1}^{N}Z_{i}^{2}P^{\perp}\Big)
\]

\end_inset


\end_layout

\begin_layout Standard
Since 
\begin_inset Formula $\{Z_{i}\}_{i=1}^{N}$
\end_inset

 are z-scored 
\begin_inset Formula $\{R_{i}\}_{i=1}^{N}$
\end_inset

,
 the sum satisfy the following identity.
 
\begin_inset Foot
status open

\begin_layout Plain Layout
Note that this constraint depends on the implementation of z-score 
\begin_inset Formula $Z_{i}=\frac{R_{i}-\mu_{R}}{\sigma_{R}}$
\end_inset

.
 In our code,
 we computed the standard deviation by 
\begin_inset Formula $\sigma_{R}^{2}=\frac{1}{N}\sum_{i=1}^{N}(R_{i}-\mu_{R})^{2}$
\end_inset

.
 In the unbiased variance estimator,
 where the denominator reads 
\begin_inset Formula $N-1$
\end_inset

,
 the identity reads 
\begin_inset Formula $\sum_{i=1}^{N}Z_{i}^{2}=N-1$
\end_inset

.
 
\end_layout

\end_inset


\begin_inset Formula 
\[
\sum_{i=1}^{N}Z_{i}^{2}=N
\]

\end_inset


\end_layout

\begin_layout Standard
Because of the following equations,
 
\begin_inset Formula 
\begin{align*}
\sigma_{R}^{2} & =\frac{1}{N}\sum_{i=1}^{N}(R_{i}-\mu_{R})^{2}\\
Z_{i} & =\frac{R_{i}-\mu_{R}}{\sigma_{R}}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Thus,
 the conditional distribution is 
\begin_inset Formula 
\[
P^{\perp}\Delta\theta\mid\{Z_{i}\}_{i=1}^{N}\sim\mathcal{N}\Big(0,\frac{\alpha^{2}}{N^{2}}NP^{\perp}\Big)
\]

\end_inset


\end_layout

\begin_layout Standard
Since the conditional distribution 
\begin_inset Formula $P^{\perp}\Delta\theta\mid\{Z_{i}\}_{i=1}^{N}$
\end_inset

 is independent of the observed reward;
 marginalize over it,
 we have 
\begin_inset Formula 
\[
P^{\perp}\Delta\theta\sim\mathcal{N}\Big(0,\frac{\alpha^{2}}{N}P^{\perp}\Big)
\]

\end_inset


\end_layout

\begin_layout Standard
The norm of off manifold component is 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\mathbb{E}\|P^{\perp}\Delta\theta\|^{2} & =\text{Tr}[\text{Var}[P^{\perp}\Delta\theta]]\\
 & =\text{Tr}\Big[\frac{\alpha^{2}}{N}P^{\perp}\Big]\\
 & =\frac{\alpha^{2}(d-1)}{N}
\end{align*}

\end_inset


\end_layout

\begin_layout Paragraph
On-manifold component
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
P^{\parallel}\Delta\theta & =\alpha\cdot\frac{1}{N}\sum_{i=1}^{N}Z_{i}P^{\parallel}\epsilon_{i}\\
 & =\alpha\cdot\frac{1}{N}\sum_{i=1}^{N}Z_{i}\epsilon_{i}^{\parallel}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
The on-manifold variable can be expressed as 
\begin_inset Formula $\epsilon_{i}^{\parallel}=\frac{\mathbf{v}}{\|\mathbf{v}\|}n_{i}$
\end_inset

,
 
\begin_inset Formula $n_{i}\sim\mathcal{N}(0,1)$
\end_inset

,
 thus reward can be written as 
\begin_inset Formula 
\begin{align*}
R_{i} & =-\sigma\mathbf{v}^{\top}\epsilon_{i}^{\parallel}+\sigma_{\xi}\xi_{i}\\
 & =-\sigma\frac{\mathbf{v}^{\top}\mathbf{v}}{\|\mathbf{v}\|}n_{i}+\sigma_{\xi}\xi_{i}\\
 & =-\sigma\|\mathbf{v}\|n_{i}+\sigma_{\xi}\xi_{i}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Recall the definition of observed reward and z-score.
 
\begin_inset Formula 
\[
Z_{i}=\frac{R_{i}-\mu_{R}}{\sigma_{R}}
\]

\end_inset


\end_layout

\begin_layout Standard
To simplify derivation,
 we use the population expectation and standard deviation here,
 
\begin_inset Formula 
\begin{align*}
\mu_{R} & \approx\mathbb{E}[R_{i}]=0\\
\sigma_{R}^{2} & \approx\text{Var}[R_{i}]=\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Under such population mean and variance simplification,
 
\begin_inset Formula 
\begin{align*}
P^{\parallel}\Delta\theta & =\frac{\alpha}{N}\sum_{i=1}^{N}Z_{i}\epsilon_{i}^{\parallel}\\
 & =\frac{\alpha}{N}\sum_{i=1}^{N}\frac{-\sigma\|\mathbf{v}\|n_{i}+\sigma_{\xi}\xi_{i}-\mu_{R}}{\sigma_{R}}n_{i}\frac{\mathbf{v}}{\|\mathbf{v}\|}\\
 & =\frac{\alpha}{N\sigma_{R}}\sum_{i=1}^{N}(-\sigma\|\mathbf{v}\|n_{i}+\sigma_{\xi}\xi_{i})n_{i}\frac{\mathbf{v}}{\|\mathbf{v}\|}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
The expectation reads 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\mathbb{E}[P^{\parallel}\Delta\theta] & =\frac{\alpha}{N\sigma_{R}}\sum_{i=1}^{N}\mathbb{E}\big[(-\sigma\|\mathbf{v}\|n_{i}+\sigma_{\xi}\xi_{i})n_{i}\big]\frac{\mathbf{v}}{\|\mathbf{v}\|}\\
 & =\frac{\alpha}{N\sigma_{R}}\mathbb{E}\big[-\sigma\|\mathbf{v}\|\sum_{i=1}^{N}n_{i}^{2}+\sigma_{\xi}\sum_{i=1}^{N}\xi_{i}n_{i}\big]\frac{\mathbf{v}}{\|\mathbf{v}\|}\\
 & =\frac{\alpha}{N\sigma_{R}}(-\sigma\|\mathbf{v}\|N)\frac{\mathbf{v}}{\|\mathbf{v}\|}\\
 & =\frac{-\sigma\alpha}{\sigma_{R}}\mathbf{v}\\
 & =\frac{-\sigma\alpha\mathbf{v}}{\sqrt{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
using independence 
\begin_inset Formula $\mathbb{E}[\xi_{i}n_{i}]=0$
\end_inset

 and chi-square 
\begin_inset Formula $\mathbb{E}[\sum_{i=1}^{N}n_{i}^{2}]=N$
\end_inset

.
 
\end_layout

\begin_layout Standard
Next consider the variance,
 consider the individual term,
 
\begin_inset Formula $X_{i}=-\sigma\|\mathbf{v}\|n_{i}^{2}+\sigma_{\xi}\xi_{i}n_{i}$
\end_inset

 and its variance 
\begin_inset Formula 
\begin{align*}
\text{Var}[X_{i}] & =\mathbb{E}[(-\sigma\|\mathbf{v}\|n_{i}^{2}+\sigma_{\xi}\xi_{i}n_{i})(-\sigma\|\mathbf{v}\|n_{i}^{2}+\sigma_{\xi}\xi_{i}n_{i})]-\mathbb{E}[-\sigma\|\mathbf{v}\|n_{i}^{2}+\sigma_{\xi}\xi_{i}n_{i}]^{2}\\
 & =\mathbb{E}[\sigma^{2}\|\mathbf{v}\|^{2}\underbrace{n_{i}^{4}}_{3}-\sigma\|\mathbf{v}\|\underbrace{\xi_{i}}_{0}\underbrace{n_{i}^{3}}_{0}+\sigma_{\xi}^{2}\underbrace{\xi_{i}^{2}}_{1}\underbrace{n_{i}^{2}}_{1}]-(\sigma\|\mathbf{v}\|)^{2}\\
 & =3\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}-(\sigma\|\mathbf{v}\|)^{2}\\
 & =2\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Thus 
\begin_inset Formula 
\begin{align*}
\text{Var}[P^{\parallel}\Delta\theta] & =\frac{\alpha^{2}}{N^{2}\sigma_{R}^{2}}N\text{Var}[X_{i}]\frac{\mathbf{v}\mathbf{v}^{\top}}{\|\mathbf{v}\|^{2}}\\
 & =\frac{\alpha^{2}(2\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2})}{N\sigma_{R}^{2}}P^{\parallel}\\
 & =\frac{\alpha^{2}(2\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2})}{N(\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2})}P^{\parallel}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\mathbb{E}[\|P^{\parallel}\Delta\theta\|^{2}] & =\text{Tr}\big[\text{Var}[P^{\parallel}\Delta\theta]\big]+\mathbb{E}[P^{\parallel}\Delta\theta]^{\top}\mathbb{E}[P^{\parallel}\Delta\theta]\\
 & =\frac{\alpha^{2}(2\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2})}{N(\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2})}+\frac{-\sigma\alpha\mathbf{v}^{\top}}{\sqrt{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}\frac{-\sigma\alpha\mathbf{v}}{\sqrt{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}\\
 & =\frac{\alpha^{2}(2\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2})}{N(\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2})}+\frac{\sigma^{2}\|\mathbf{v}\|^{2}\alpha^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}\\
 & =\frac{\alpha^{2}}{N}+(1+\frac{1}{N})\frac{\sigma^{2}\|\mathbf{v}\|^{2}\alpha^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}
\end{align*}

\end_inset


\end_layout

\begin_layout Paragraph
Manifold alignment of update
\end_layout

\begin_layout Standard
Consider the ratio of on and off manifold movement 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\mathbb{E}[\|P^{\parallel}\Delta\theta\|^{2}]=\frac{\alpha^{2}}{N}+(1+\frac{1}{N})\frac{\sigma^{2}\|\mathbf{v}\|^{2}\alpha^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}
\]

\end_inset


\begin_inset Formula 
\[
\mathbb{E}\|P^{\perp}\Delta\theta\|^{2}=\frac{\alpha^{2}(d-1)}{N}
\]

\end_inset


\end_layout

\begin_layout Standard
The fraction of squared norm for on manifold deviation out of the total deviation
\begin_inset Formula 
\begin{align*}
\rho=\frac{\mathbb{E}[\|P^{\parallel}\Delta\theta\|^{2}]}{\mathbb{E}[\|\Delta\theta\|^{2}]} & =\frac{\mathbb{E}[\|P^{\parallel}\Delta\theta\|^{2}]}{\mathbb{E}[\|P^{\parallel}\Delta\theta\|^{2}]+\mathbb{E}\|P^{\perp}\Delta\theta\|^{2}}\\
 & =\frac{\frac{\alpha^{2}}{N}+(1+\frac{1}{N})\frac{\sigma^{2}\|\mathbf{v}\|^{2}\alpha^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}{\frac{\alpha^{2}(d-1)}{N}+\frac{\alpha^{2}}{N}+(1+\frac{1}{N})\frac{\sigma^{2}\|\mathbf{v}\|^{2}\alpha^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}\\
 & =\frac{\frac{\alpha^{2}}{N}+(1+\frac{1}{N})\frac{\sigma^{2}\|\mathbf{v}\|^{2}\alpha^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}{\frac{\alpha^{2}d}{N}+(1+\frac{1}{N})\frac{\sigma^{2}\|\mathbf{v}\|^{2}\alpha^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}\\
 & =\frac{\frac{1}{N}+\frac{N+1}{N}\frac{\sigma^{2}\|\mathbf{v}\|^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}{\frac{d}{N}+\frac{N+1}{N}\frac{\sigma^{2}\|\mathbf{v}\|^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}\\
 & =\frac{1+(N+1)\frac{\sigma^{2}\|\mathbf{v}\|^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}{d+(N+1)\frac{\sigma^{2}\|\mathbf{v}\|^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}}\\
 & =\frac{1+(N+1)s}{d+(N+1)s}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
where 
\begin_inset Formula $s:=\frac{\sigma^{2}\|\mathbf{v}\|^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}$
\end_inset

.
 
\end_layout

\begin_layout Standard
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\[
=\frac{(\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2})+(N+1)\sigma^{2}\|\mathbf{v}\|^{2}}{d(\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2})+(N+1)\sigma^{2}\|\mathbf{v}\|^{2}}
\]

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Standard
This formulation reveals the key scaling relation of on and off manifold movement 
\end_layout

\begin_layout Itemize
Signal to noise ratio 
\begin_inset Formula $s:=\frac{\sigma^{2}\|\mathbf{v}\|^{2}}{\sigma^{2}\|\mathbf{v}\|^{2}+\sigma_{\xi}^{2}}$
\end_inset

 ,
 which range from 
\begin_inset Formula $s\in[0,1]$
\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
When no gradient exists,
 
\begin_inset Formula $\|\mathbf{v}\|^{2}=0$
\end_inset

,
 then independent of number of sample 
\begin_inset Formula $N$
\end_inset

,
 
\begin_inset Formula $\rho=1/d$
\end_inset

.
 i.e.
 the norm on one axis among 
\begin_inset Formula $d$
\end_inset

 axis is 
\begin_inset Formula $1/d$
\end_inset

.
\end_layout

\begin_layout Itemize
Similarly,
 when 
\begin_inset Formula $\sigma_{\xi}^{2}\gg\sigma^{2}\|\mathbf{v}\|^{2}$
\end_inset

 i.e.
 the reward noise variance is much higher than the variation of signal under exploration range 
\begin_inset Formula $\sigma$
\end_inset

,
 then it's effectively no gradient and no guidance.
 
\end_layout

\begin_layout Itemize
In the other extreme,
 when very little reward noise,
 
\begin_inset Formula $\sigma_{\xi}^{2}\ll\sigma^{2}\|\mathbf{v}\|^{2}$
\end_inset

,
 
\begin_inset Formula $s\approx1$
\end_inset

,
 then 
\begin_inset Formula $\rho=\frac{N+2}{d+N+1}$
\end_inset

.
 
\end_layout

\begin_layout Itemize
Via differentiation,
 one can show,
 
\begin_inset Formula $\rho$
\end_inset

 monotonically depends on signal to noise ratio 
\begin_inset Formula $s$
\end_inset


\end_layout

\end_deeper
\begin_layout Itemize
Full dimension 
\begin_inset Formula $d$
\end_inset

.
 Increase the full space dim 
\begin_inset Formula $d$
\end_inset

 will monotonically decrease the on manifold fraction 
\begin_inset Formula $\rho$
\end_inset

.
 
\end_layout

\begin_layout Itemize
Sample size per generation 
\begin_inset Formula $N$
\end_inset

.
 Increase the sample size 
\begin_inset Formula $N$
\end_inset

 will monotonically increase the on manifold fraction 
\begin_inset Formula $\rho$
\end_inset

.
 
\end_layout

\begin_deeper
\begin_layout Itemize
Note this scaling is almost linear,
 so to get half of the variance on manifold,
 one need 
\begin_inset Formula $(N+1)s\approx d$
\end_inset

.
 In reality,
 
\begin_inset Formula $d\sim10^{9}$
\end_inset

 ,
 which makes this impossible.
 
\end_layout

\begin_layout Itemize
In most realistic regimes 
\begin_inset Formula $N\ll d$
\end_inset

,
 which makes this on manifold ratio per step nearly negligible.
 
\end_layout

\end_deeper
\begin_layout Subsubsection
Quadratic landscape analysis
\end_layout

\begin_layout Standard
Consider a quadratic potential centered / peaked at the origin 
\begin_inset Formula $\theta^{*}=0$
\end_inset

.
 
\begin_inset Formula 
\[
R(\theta)=-\frac{1}{2}\theta^{\top}Q\theta
\]

\end_inset


\end_layout

\begin_layout Standard
At current state 
\begin_inset Formula $\theta_{0}$
\end_inset

,
 the reward at perturbed locations with observation noise are,
 where 
\begin_inset Formula $\xi_{i}\sim\mathcal{N}(0,1)$
\end_inset

,
 
\begin_inset Formula $\epsilon_{i}\sim\mathcal{N}(0,I_{d})$
\end_inset


\begin_inset Formula 
\begin{align*}
R_{i} & =R(\theta_{0}+\sigma\epsilon_{i})+\sigma_{\xi}\xi_{i}\\
 & =-\frac{1}{2}(\theta_{0}+\sigma\epsilon_{i})^{\top}Q(\theta_{0}+\sigma\epsilon_{i})+\sigma_{\xi}\xi_{i}\\
 & =-\frac{1}{2}\theta_{0}^{\top}Q\theta_{0}-\sigma\,\theta_{0}^{\top}Q\epsilon_{i}-\frac{\sigma^{2}}{2}\epsilon_{i}^{\top}Q\epsilon_{i}+\sigma_{\xi}\xi_{i}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Expectation of reward reads,
 which is the population mean of reward samples 
\begin_inset Formula 
\[
\mathbb{E}[R_{i}]=-\frac{1}{2}\theta_{0}^{\top}Q\theta_{0}-\frac{\sigma^{2}}{2}\mathrm{Tr}Q
\]

\end_inset


\end_layout

\begin_layout Standard
Center the rewards with population mean,
 we define 
\begin_inset Formula 
\[
\tilde{R}_{i}:=R_{i}-\mathbb{E}[R_{i}]
\]

\end_inset


\end_layout

\begin_layout Standard
Centered reward has three terms,
 linear 
\begin_inset Formula $A$
\end_inset

,
 quadratic 
\series bold

\begin_inset Formula $B$
\end_inset


\series default
,
 and noise 
\begin_inset Formula $C$
\end_inset

 
\begin_inset Formula 
\[
\tilde{R}_{i}=\underbrace{-\sigma\,\theta_{0}^{\top}Q\epsilon_{i}}_{\text{linear }A}\underbrace{-\frac{\sigma^{2}}{2}(\epsilon_{i}^{\top}Q\epsilon_{i}-\mathrm{Tr}Q)}_{\text{quad }B}+\underbrace{\sigma_{\xi}\xi_{i}}_{\text{scalar noise }C}
\]

\end_inset


\end_layout

\begin_layout Standard
One can abbreviate 
\begin_inset Formula $\mathbf{v}:=Q^{\top}\theta_{0}$
\end_inset

 as the negative gradient.
 
\end_layout

\begin_layout Standard
The weight update reads,
 
\begin_inset Formula 
\begin{align*}
\Delta\theta & =\alpha\cdot\frac{1}{N}\sum_{i=1}^{N}Z_{i}\epsilon_{i}\\
 & =\frac{\alpha}{N\sigma_{R}}\sum_{i=1}^{N}\tilde{R}_{i}\epsilon_{i}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Since perturbations 
\begin_inset Formula $\tilde{R}_{i}\epsilon_{i}$
\end_inset

 are i.i.d.
 sampled 
\begin_inset Formula 
\[
\mathbb{E}[\Delta\theta]=\frac{\alpha}{\sigma_{R}}\mathbb{E}[\tilde{R}_{i}\epsilon_{i}]
\]

\end_inset


\end_layout

\begin_layout Standard
and 
\begin_inset Formula 
\[
\mathrm{Cov}[\Delta\theta]=\frac{\alpha^{2}}{N\sigma_{R}^{2}}\mathrm{Cov}[\tilde{R}_{i}\epsilon_{i}]
\]

\end_inset


\end_layout

\begin_layout Standard
One observe that both 
\begin_inset Formula $\tilde{R}_{i}$
\end_inset

 and 
\begin_inset Formula $\tilde{R}_{i}\epsilon_{i}$
\end_inset

 are 
\series bold
polynomial functions of gaussian random variables
\series default
 
\begin_inset Formula $\epsilon_{i}$
\end_inset

 and 
\begin_inset Formula $\xi_{i}$
\end_inset

 (up to 3rd order),
 thus we can compute 
\series bold
their moment of any order
\series default
 via Wick-Isserlis theorem 
\backslash
cite,
 writing out mean and covariance of them.
\end_layout

\begin_layout Standard
Here are the specific calculations 
\end_layout

\begin_layout Paragraph
Reward variance
\end_layout

\begin_layout Standard
Note that all three terms 
\begin_inset Formula $A,B,C$
\end_inset

 are centered 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[A] & =0\\
\mathbb{E}[B] & =0\\
\mathbb{E}[C] & =0
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Further 
\begin_inset Formula $A\perp C$
\end_inset

,
 
\begin_inset Formula $B\perp C$
\end_inset

 due to independence of noise,
 and 
\begin_inset Formula 
\[
\mathbb{E}[AB]=0
\]

\end_inset


\end_layout

\begin_layout Standard
as it only has polynomial of 
\begin_inset Formula $\epsilon_{i}$
\end_inset

 of odd order 1 and 3,
 thus its expectation is 0.
 Thus,
 
\begin_inset Formula $A,B,C$
\end_inset

 are not correlated with one another.
 Thus,
 
\begin_inset Formula 
\begin{align*}
\mathrm{Var}[\tilde{R}_{i}] & =\mathbb{E}[\tilde{R}_{i}^{2}]\\
 & =\mathbb{E}[A^{2}]+\mathbb{E}[B^{2}]+\mathbb{E}[C^{2}]
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
all cross terms vanish due to no correlation.
\begin_inset Formula 
\begin{align*}
\mathbb{E}[A^{2}] & =\mathbb{E}[(-\sigma\,\theta_{0}^{\top}Q\epsilon_{i})\cdot(-\sigma\,\theta_{0}^{\top}Q\epsilon_{i})]\\
 & =\sigma^{2}\theta_{0}^{\top}QQ^{\top}\theta_{0}\\
 & =\sigma^{2}\|\mathbf{v}\|^{2}
\end{align*}

\end_inset


\begin_inset Formula 
\[
\mathbb{E}[C^{2}]=\sigma_{\xi}^{2}
\]

\end_inset


\begin_inset Formula 
\begin{align*}
\mathbb{E}[B^{2}] & =\mathbb{E}[(\frac{\sigma^{2}}{2}(\epsilon_{i}^{\top}Q\epsilon_{i}-\mathrm{Tr}Q))^{2}]\\
 & =\frac{\sigma^{4}}{4}\mathbb{E}[\epsilon_{i}^{\top}Q\epsilon_{i}\cdot(\epsilon_{i}^{\top}Q\epsilon_{i}-\mathrm{Tr}Q)-\mathrm{Tr}Q\cdot(\epsilon_{i}^{\top}Q\epsilon_{i}-\mathrm{Tr}Q)]\\
 & =\frac{\sigma^{4}}{4}\Big(\mathbb{E}[\epsilon_{i}^{\top}Q\epsilon_{i}\cdot\epsilon_{i}^{\top}Q\epsilon_{i}]-(\mathrm{Tr}Q)^{2}\Big)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
The first quintic polynomial of 
\begin_inset Formula $\epsilon_{i}$
\end_inset

 can be tackled by Wick-Isserelis theorem.
 With slight mis-use of notation,
 here we let 
\begin_inset Formula $\epsilon_{a}$
\end_inset

 denote the 
\begin_inset Formula $a$
\end_inset

th element of 
\begin_inset Formula $\epsilon_{i}$
\end_inset

 vector.
\end_layout

\begin_layout Standard
Then 
\begin_inset Formula 
\[
\mathbb{E}[\epsilon_{a}\epsilon_{b}\epsilon_{c}\epsilon_{d}]=I_{ab}I_{cd}+I_{ad}I_{bc}+I_{ac}I_{bd}
\]

\end_inset


\end_layout

\begin_layout Standard
thus 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[\epsilon_{i}^{\top}Q\epsilon_{i}\cdot\epsilon_{i}^{\top}Q\epsilon_{i}] & =\mathbb{E}[\sum_{a,b,c,d}Q_{ab}Q_{cd}\epsilon_{a}\epsilon_{b}\epsilon_{c}\epsilon_{d}]\\
 & =\sum_{a,b,c,d}Q_{ab}Q_{cd}\mathbb{E}[\epsilon_{a}\epsilon_{b}\epsilon_{c}\epsilon_{d}]\\
 & =\sum_{a,b,c,d}Q_{ab}Q_{cd}(\delta_{ab}\delta_{cd}+\delta_{ac}\delta_{bd}+\delta_{ad}\delta_{bc})\\
 & =\mathrm{Tr}Q\mathrm{Tr}Q+\mathrm{Tr}[Q^{\top}Q]+\mathrm{Tr}[QQ]
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Thus 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[B^{2}] & =\frac{\sigma^{4}}{4}\Big(\mathbb{E}[\epsilon_{i}^{\top}Q\epsilon_{i}\cdot\epsilon_{i}^{\top}Q\epsilon_{i}]-(\mathrm{Tr}Q)^{2}\Big)\\
 & =\frac{\sigma^{4}}{4}\Big((\mathrm{Tr}Q)^{2}+2\mathrm{Tr}[Q^{2}]-(\mathrm{Tr}Q)^{2}\Big)\\
 & =\frac{\sigma^{4}}{2}\mathrm{Tr}[Q^{2}]
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
In sum,
 the population variance of reward reads,
 
\begin_inset Formula 
\[
\mathrm{Var}[\tilde{R}_{i}]=\sigma^{2}\|\mathbf{v}\|^{2}+\frac{\sigma^{4}}{2}\mathrm{Tr}[Q^{2}]+\sigma_{\xi}^{2}
\]

\end_inset


\end_layout

\begin_layout Standard
and the population standard deviation is 
\begin_inset Formula 
\[
\sigma_{R}=\sqrt{\sigma^{2}\|\mathbf{v}\|^{2}+\frac{\sigma^{4}}{2}\mathrm{Tr}[Q^{2}]+\sigma_{\xi}^{2}}
\]

\end_inset


\end_layout

\begin_layout Paragraph
Expectation of parameter update
\end_layout

\begin_layout Standard
Next let's examine expectation of parameter change,
 where the key is 
\begin_inset Formula $\mathbb{E}[\tilde{R}_{i}\epsilon_{i}]$
\end_inset

,
 decomposing into three terms
\begin_inset Formula 
\[
\mathbb{E}[\tilde{R}_{i}\epsilon_{i}]=\mathbb{E}[A\epsilon_{i}]+\mathbb{E}[B\epsilon_{i}]+\mathbb{E}[C\epsilon_{i}]
\]

\end_inset


\end_layout

\begin_layout Standard
Second term vanish due to the odd order of Gaussian variable,
 
\begin_inset Formula 
\[
\mathbb{E}[B\epsilon_{i}]=0
\]

\end_inset


\end_layout

\begin_layout Standard
Third term vanish due to independence 
\begin_inset Formula $\epsilon_{i}\perp\xi_{i}$
\end_inset


\begin_inset Formula 
\[
\mathbb{E}[C\epsilon_{i}]=0
\]

\end_inset


\end_layout

\begin_layout Standard
First term is easy to calculate 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[A\epsilon_{i}] & =\mathbb{E}[(-\sigma\,\theta_{0}^{\top}Q\epsilon_{i})\epsilon_{i}]\\
 & =-\sigma\mathbb{E}[\epsilon_{i}(\epsilon_{i}^{\top}\mathbf{v})]\\
 & =-\sigma\mathbf{v}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
So in sum,
 
\begin_inset Formula 
\[
\mathbb{E}[\tilde{R}_{i}\epsilon_{i}]=-\sigma\mathbf{v}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\mathbb{E}[\Delta\theta] & =\frac{\alpha}{\sigma_{R}}\mathbb{E}[\tilde{R}_{i}\epsilon_{i}]\\
 & =\frac{-\alpha\sigma\mathbf{v}}{\sigma_{R}}\\
 & =\frac{-\alpha\sigma\mathbf{v}}{\sqrt{\sigma^{2}\|\mathbf{v}\|^{2}+\frac{\sigma^{4}}{2}\mathrm{Tr}[Q^{2}]+\sigma_{\xi}^{2}}}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
which is on expectation aligned with local gradient direction,
 but scaled by signal to noise ratio.
 
\end_layout

\begin_layout Paragraph
Variance of parameter update
\end_layout

\begin_layout Standard
Finally,
 let's examine variance of parameter change,
 where the key is 
\begin_inset Formula $\mathrm{Cov}[\tilde{R}_{i}\epsilon_{i}]$
\end_inset

,
\begin_inset Formula 
\begin{align*}
\mathrm{Cov}[\tilde{R}_{i}\epsilon_{i}] & =\mathbb{E}[\tilde{R}_{i}\epsilon_{i}(\tilde{R}_{i}\epsilon_{i})^{\top}]-\mathbb{E}[\tilde{R}_{i}\epsilon_{i}]\mathbb{E}[\tilde{R}_{i}\epsilon_{i}]^{\top}\\
 & =\mathbb{E}[\tilde{R}_{i}^{2}\epsilon_{i}\epsilon_{i}^{\top}]-\sigma^{2}\mathbf{v}\mathbf{v}^{\top}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Tackling the first term,
 using the same logic (odd order and independence) to eliminate terms,
 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[\tilde{R}_{i}^{2}\epsilon_{i}\epsilon_{i}^{\top}] & =\mathbb{E}[(A+B+C)^{2}\epsilon_{i}\epsilon_{i}^{\top}]\\
 & =\mathbb{E}[(A^{2}+B^{2}+C^{2}+2AB+2BC+2AC)\epsilon_{i}\epsilon_{i}^{\top}]\\
 & =\mathbb{E}[(A^{2}+B^{2}+C^{2})\epsilon_{i}\epsilon_{i}^{\top}]
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Tackle 
\begin_inset Formula $C$
\end_inset

 term.
 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[C^{2}\epsilon_{i}\epsilon_{i}^{\top}] & =\mathbb{E}[C^{2}]\mathbb{E}[\epsilon_{i}\epsilon_{i}^{\top}]\\
 & =\sigma_{\xi}^{2}I_{d}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Tackle 
\series bold

\begin_inset Formula $A$
\end_inset


\series default
 term
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\mathbb{E}[A^{2}\epsilon_{i}\epsilon_{i}^{\top}] & =\mathbb{E}[(-\sigma\,\theta_{0}^{\top}Q\epsilon_{i})^{2}\epsilon_{i}\epsilon_{i}^{\top}]\\
 & =\sigma^{2}\mathbb{E}[(\mathbf{v}^{\top}\epsilon_{i})^{2}\epsilon_{i}\epsilon_{i}^{\top}]
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
using the same Wick theorem trick we have each element 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[(\mathbf{v}^{\top}\epsilon_{i})^{2}\epsilon_{i}\epsilon_{i}^{\top}]_{cd} & =\mathbb{E}[\sum_{a,b}\mathbf{v}_{a}\mathbf{v}_{b}\epsilon_{a}\epsilon_{b}\epsilon_{c}\epsilon_{d}]\\
 & =\sum_{a,b}\mathbf{v}_{a}\mathbf{v}_{b}\mathbb{E}[\epsilon_{a}\epsilon_{b}\epsilon_{c}\epsilon_{d}]\\
 & =\sum_{a,b}\mathbf{v}_{a}\mathbf{v}_{b}(\delta_{ab}\delta_{cd}+\delta_{ac}\delta_{bd}+\delta_{ad}\delta_{cb})\\
 & =\|\mathbf{v}\|^{2}\delta_{cd}+\mathbf{v}_{c}\mathbf{v}_{d}+\mathbf{v}_{d}\mathbf{v}_{c}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Thus,
 
\begin_inset Formula 
\[
\mathbb{E}[A^{2}\epsilon_{i}\epsilon_{i}^{\top}]=\sigma^{2}(\|\mathbf{v}\|^{2}I_{d}+2\mathbf{v}\mathbf{v}^{\top})
\]

\end_inset


\end_layout

\begin_layout Standard
Finally,
 tackle 
\begin_inset Formula $B$
\end_inset

 term 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[B^{2}\epsilon_{i}\epsilon_{i}^{\top}] & =\mathbb{E}[(\frac{\sigma^{2}}{2}(\epsilon_{i}^{\top}Q\epsilon_{i}-\mathrm{Tr}Q))^{2}\epsilon_{i}\epsilon_{i}^{\top}]\\
 & =\frac{\sigma^{4}}{4}\mathbb{E}[\Big((\epsilon_{i}^{\top}Q\epsilon_{i})^{2}-2\mathrm{Tr}Q\cdot\epsilon_{i}^{\top}Q\epsilon_{i}+(\mathrm{Tr}Q)^{2}\Big)\epsilon_{i}\epsilon_{i}^{\top}]
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
where we encounter 2nd,
 4th and 6th order terms.
 
\end_layout

\begin_layout Standard
2nd order term
\begin_inset Formula 
\[
\mathbb{E}[(\mathrm{Tr}Q)^{2}\epsilon_{i}\epsilon_{i}^{\top}]=(\mathrm{Tr}Q)^{2}I_{d}
\]

\end_inset


\end_layout

\begin_layout Standard
4th order term 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[\epsilon_{i}^{\top}Q\epsilon_{i}\cdot\epsilon_{i}\epsilon_{i}^{\top}]_{cd} & =\mathbb{E}[\sum_{a,b}Q_{ab}\epsilon_{a}\epsilon_{b}\epsilon_{c}\epsilon_{d}]\\
 & =\sum_{a,b}Q_{ab}(\delta_{ab}\delta_{cd}+\delta_{ac}\delta_{bd}+\delta_{ad}\delta_{cb})\\
 & =\mathrm{Tr}Q\cdot\delta_{cd}+Q_{cd}+Q_{dc}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Thus
\begin_inset Formula 
\begin{align*}
\mathbb{E}[\epsilon_{i}^{\top}Q\epsilon_{i}\cdot\epsilon_{i}\epsilon_{i}^{\top}] & =\mathrm{Tr}Q\cdot I_{d}+Q+Q^{\top}\\
 & =\mathrm{Tr}Q\cdot I_{d}+2Q
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
6th order term
\begin_inset Formula 
\[
\mathbb{E}[\Big((\epsilon_{i}^{\top}Q\epsilon_{i})^{2}\Big)\epsilon_{i}\epsilon_{i}^{\top}]_{ef}=\mathbb{E}[\sum_{a,b,c,d}Q_{ab}Q_{cd}\epsilon_{a}\epsilon_{b}\epsilon_{c}\epsilon_{d}\epsilon_{e}\epsilon_{f}]
\]

\end_inset


\end_layout

\begin_layout Standard
Note this has 
\begin_inset Formula $C_{6}^{2}=15$
\end_inset

 pairings,
 with some diagrammatic reasoning,
 we can find topologically we have three types 
\begin_inset Formula 
\begin{align*}
\mathbb{E}[\Big((\epsilon_{i}^{\top}Q\epsilon_{i})^{2}\Big)\epsilon_{i}\epsilon_{i}^{\top}]_{ef} & =\mathbb{E}[\sum_{a,b,c,d}Q_{ab}Q_{cd}\epsilon_{a}\epsilon_{b}\epsilon_{c}\epsilon_{d}\epsilon_{e}\epsilon_{f}]\\
 & =\sum_{a,b,c,d}Q_{ab}Q_{cd}\Big(\underbrace{\delta_{ab}\delta_{cd}\delta_{ef}}_{1\text{case}}+\underbrace{\delta_{ac}\delta_{bd}\delta_{ef}+...}_{2\text{case}}+\\
 & \quad\quad\underbrace{\delta_{ae}\delta_{bf}\delta_{cd}+...}_{4\text{case}}+\underbrace{\delta_{ae}\delta_{cf}\delta_{bd}+...}_{8\text{case}}\Big)\\
 & =((\mathrm{Tr}Q)^{2}+2\mathrm{Tr}Q^{2})\delta_{ef}+4\mathrm{Tr}Q\cdot Q_{ef}+8[Q^{2}]_{ef}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Thus 
\begin_inset Formula 
\[
\mathbb{E}[\Big((\epsilon_{i}^{\top}Q\epsilon_{i})^{2}\Big)\epsilon_{i}\epsilon_{i}^{\top}]=((\mathrm{Tr}Q)^{2}+2\mathrm{Tr}Q^{2})I_{d}+4\mathrm{Tr}Q\cdot Q+8Q^{2}
\]

\end_inset


\end_layout

